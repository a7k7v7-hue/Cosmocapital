# Railway — переменные окружения
# Скопируй в Railway → Variables (не в файл .env)

NODE_ENV=production

# URL приложения на Railway (обнови после первого деплоя)
NEXTAUTH_URL=https://xxx.railway.app

# Генерируй: openssl rand -hex 32
NEXTAUTH_SECRET=fill-in

# Учётные данные администратора
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=fill-in

# Токен для Telegram-бота. Генерируй: openssl rand -hex 24
API_TOKEN=fill-in

# Supabase → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co

# Railway добавляет автоматически при связке с Postgres
# DATABASE_URL=postgresql://...
