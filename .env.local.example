# Supabase — supabase.com -> Settings -> Database
# DATABASE_URL: строка подключения через pgBouncer (для Prisma в проде)
DATABASE_URL=

# DIRECT_URL: прямое подключение (для prisma migrate)
DIRECT_URL=

# Supabase JS client — supabase.com -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NextAuth — сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Учетные данные администратора /admin (задать при деплое)
ADMIN_EMAIL=
ADMIN_PASSWORD=
