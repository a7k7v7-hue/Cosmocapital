# Supabase — supabase.com -> Settings -> Database
# DATABASE_URL: строка подключения через pgBouncer (для Prisma в проде)
DATABASE_URL=

# Для prisma migrate dev используй прямое подключение без pgBouncer (порт 5432)
# Временно подставь в DATABASE_URL прямую строку подключения, запусти migrate, верни pooler

# Supabase JS client — supabase.com -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NextAuth — сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Учетные данные администратора /admin (задать при деплое)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# API-токен для внешних клиентов (Telegram-бот, agent1)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Если не задан - API открыт (только для локальной разработки)
API_TOKEN=
